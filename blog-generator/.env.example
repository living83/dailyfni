# Claude API 키
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# 마스터 암호화 키 (AES-256, 반드시 변경하세요!)
# 최소 16자 이상의 임의 문자열을 사용하세요
MASTER_KEY=change-this-to-a-very-long-random-string-at-least-32-chars

# MySQL 데이터베이스 설정
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DB=dailyfni

# 보안 설정
# CORS 허용 도메인 (콤마 구분)
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# 분당 최대 API 요청 수
RATE_LIMIT_MAX=30

# 블로그 하단 링크 (선택)
DEFAULT_FOOTER_LINK=http://pf.kakao.com/_XEUIX/chat
DEFAULT_FOOTER_LINK_TEXT=카카오톡 상담하기
